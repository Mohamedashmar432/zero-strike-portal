# Copied to deploy/.env (gitignored) for docker compose --env-file/env_file.
CADDY_DOMAIN=portal.zerostrike.ai
CADDY_EMAIL=admin@zerostrike.ai

MONGODB_DB_NAME=zerostrike
CORS_ORIGINS=["https://portal.zerostrike.ai"]
ARTIFACT_STORAGE_PATH=/data/artifacts
CLONE_WORKDIR_PATH=/tmp/zs-clones

# Server-side (cloud) scan tuning.
SCAN_TIMEOUT_SECONDS=900
MAX_CONCURRENT_CLOUD_SCANS=2

NEXT_PUBLIC_API_BASE_URL=/api/v1
# Shown in the UI's local/CI setup instructions as `--server <origin>` (no /api/v1 suffix).
NEXT_PUBLIC_PORTAL_ORIGIN=https://portal.zerostrike.ai

# Pin the CGO-enabled scanner build baked into the backend image (see backend/Dockerfile).
SCANNER_REF=v0.22.0

# Secrets (MONGODB_URI, JWT_SECRET) are NOT set here — see deploy/secrets/*.txt.example
