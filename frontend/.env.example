NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Origin shown in local/CI scan setup as `--server <origin>` (no /api/v1 suffix), and used to
# build the scanner-binary download URL. This is always your BACKEND's origin, never the
# frontend's — even in a split deploy (Vercel+Railway) where they're different hosts. The
# scanner CLI/CI pipelines call the backend's REST API directly; they never go through the
# frontend. In production behind Caddy (single-origin deploy) this happens to equal the
# portal's public origin too, since frontend and backend share one host there.
NEXT_PUBLIC_SCANNER_SERVER_ORIGIN=http://localhost:8000
