MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=zerostrike
JWT_SECRET=dev-secret-change-me
CORS_ORIGINS=["http://localhost:3000"]

# Server-side (cloud) scan execution — the scanner runs as a subprocess, no Docker needed.
# Local Windows: point at the prebuilt binary in the sibling scanner repo, e.g.
#   SCANNER_BINARY_PATH=C:\Users\<you>\playground\zero-strike-code-scanner\zerostrike.exe
# In the container the binary is on PATH, so "zerostrike" is enough.
SCANNER_BINARY_PATH=zerostrike
# CLONE_WORKDIR_PATH=            # empty => OS temp dir/zs-clones
# SCAN_TIMEOUT_SECONDS=900
# MAX_CONCURRENT_CLOUD_SCANS=2
